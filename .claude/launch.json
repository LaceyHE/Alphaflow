{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "AlphaFlow Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "frontend"
    },
    {
      "name": "AlphaFlow Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--port", "8000", "--reload"],
      "port": 8000,
      "cwd": "backend"
    }
  ]
}
